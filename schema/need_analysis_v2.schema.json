{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://cognitivestaffing/schema/need_analysis_v2.schema.json",
  "title": "NeedAnalysisV2",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "intake",
    "role",
    "work",
    "requirements",
    "constraints",
    "selection",
    "evidence",
    "open_decisions",
    "warnings"
  ],
  "properties": {
    "intake": {
      "type": "object",
      "additionalProperties": false,
      "required": ["source_language", "raw_input", "target_locale"],
      "properties": {
        "source_language": {"type": "string"},
        "raw_input": {"type": "string"},
        "target_locale": {"type": "string"}
      }
    },
    "role": {
      "type": "object",
      "additionalProperties": false,
      "required": ["title", "summary", "seniority", "department", "team", "reports_to"],
      "properties": {
        "title": {"type": "string"},
        "summary": {"type": "string"},
        "seniority": {"type": "string"},
        "department": {"type": "string"},
        "team": {"type": "string"},
        "reports_to": {"type": "string"}
      }
    },
    "work": {
      "type": "object",
      "additionalProperties": false,
      "required": ["responsibilities", "location", "work_policy", "travel_required"],
      "properties": {
        "responsibilities": {"type": "array", "items": {"type": "string"}},
        "location": {"type": "string"},
        "work_policy": {"type": "string"},
        "travel_required": {"type": ["boolean", "null"]}
      }
    },
    "requirements": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "hard_skills_required",
        "hard_skills_optional",
        "soft_skills_required",
        "soft_skills_optional",
        "languages_required",
        "certifications"
      ],
      "properties": {
        "hard_skills_required": {"type": "array", "items": {"type": "string"}},
        "hard_skills_optional": {"type": "array", "items": {"type": "string"}},
        "soft_skills_required": {"type": "array", "items": {"type": "string"}},
        "soft_skills_optional": {"type": "array", "items": {"type": "string"}},
        "languages_required": {"type": "array", "items": {"type": "string"}},
        "certifications": {"type": "array", "items": {"type": "string"}}
      }
    },
    "constraints": {
      "type": "object",
      "additionalProperties": false,
      "required": ["visa_sponsorship", "salary_min", "salary_max", "currency", "timeline"],
      "properties": {
        "visa_sponsorship": {"type": ["boolean", "null"]},
        "salary_min": {"type": ["number", "null"]},
        "salary_max": {"type": ["number", "null"]},
        "currency": {"type": "string"},
        "timeline": {"type": "string"}
      }
    },
    "selection": {
      "type": "object",
      "additionalProperties": false,
      "required": ["process_steps", "stakeholders"],
      "properties": {
        "process_steps": {"type": "array", "items": {"type": "string"}},
        "stakeholders": {"type": "array", "items": {"type": "string"}}
      }
    },
    "evidence": {
      "type": "array",
      "items": {"$ref": "#/$defs/EvidenceItem"}
    },
    "open_decisions": {
      "type": "array",
      "items": {"$ref": "#/$defs/DecisionCard"}
    },
    "warnings": {
      "type": "array",
      "items": {"type": "string"}
    }
  },
  "$defs": {
    "EvidenceItem": {
      "type": "object",
      "additionalProperties": false,
      "required": ["field_path", "value", "source", "confidence", "excerpt"],
      "properties": {
        "field_path": {"type": "string"},
        "value": {},
        "source": {"type": "string", "enum": ["user", "llm", "heuristic", "import"]},
        "confidence": {"type": "number", "minimum": 0, "maximum": 1},
        "excerpt": {"type": "string"}
      }
    },
    "DecisionCard": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "decision_id",
        "title",
        "field_path",
        "decision_state",
        "proposed_value",
        "rationale"
      ],
      "properties": {
        "decision_id": {"type": "string"},
        "title": {"type": "string"},
        "field_path": {"type": "string"},
        "decision_state": {"type": "string", "enum": ["proposed", "confirmed", "rejected"]},
        "proposed_value": {},
        "rationale": {"type": "string"}
      }
    }
  }
}
