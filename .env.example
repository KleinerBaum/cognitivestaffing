# Cognitive Staffing defaults (strict nano-only runtime)
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_REQUEST_TIMEOUT=120
OPENAI_ORGANIZATION=
OPENAI_PROJECT=

# Non-embedding generation: locked to gpt-5-nano in strict mode
STRICT_NANO_ONLY=true
OPENAI_MODEL=gpt-5-nano
DEFAULT_MODEL=gpt-5-nano
LIGHTWEIGHT_MODEL=gpt-5-nano
MEDIUM_REASONING_MODEL=gpt-5-nano
HIGH_REASONING_MODEL=gpt-5-nano
REASONING_EFFORT=minimal
VERBOSITY=low

# Responses + tools
RESPONSES_ALLOW_TOOLS=true

# Optional retrieval
VECTOR_STORE_ID=
EMBED_MODEL=text-embedding-3-large
